# Monorepo .gitignore for LocalMiner

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build and framework outputs
.next/
out/
build/
dist/
coverage/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Environment files
.env
.env.*
!.env.example

# Deployment
.vercel/

# OS and editor files
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Misc
*.pem
